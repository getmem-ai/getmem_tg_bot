# ═════════════════════════════════════════════════════════════════════════════
#  GetMem Telegram Bot — configuration
#  Copy to `.env` and fill in. Only the first section is strictly required.
#  (For Dokploy you don't use a .env file — paste these into the Dokploy UI.)
# ═════════════════════════════════════════════════════════════════════════════

# ── Required ──────────────────────────────────────────────────────────────────
# Telegram bot token from @BotFather
BOT_TOKEN=
# OpenRouter API key (free): https://openrouter.ai/keys
OPENROUTER_API_KEY=
# GetMem memory key (gm_live_...): https://getmem.ai  — the whole point of the bot.
# Leave empty to run WITHOUT long-term memory.
GETMEM_API_KEY=

# ── OpenRouter / models ──────────────────────────────────────────────────────
APP_NAME=GetMem Telegram Bot
APP_URL=https://github.com/getmem-ai/getmem_tg_bot
# Comma-separated; tried in order (OpenRouter falls back automatically).
# FREE_MODELS=deepseek/deepseek-chat-v3-0324:free,meta-llama/llama-3.3-70b-instruct:free,google/gemini-2.0-flash-exp:free
# PREMIUM_MODELS=anthropic/claude-sonnet-4-6,openai/gpt-4o,google/gemini-2.5-pro
# Extra providers (OpenAI, Anthropic, Groq, DeepSeek, Mistral, Gemini, Ollama)
# are enabled with their API keys from the admin dashboard (Providers tab) — no
# env needed. For local models via Ollama, point this at your Ollama server:
# OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
REQUEST_TIMEOUT=60
# Overall cap for producing one reply (across model rotation). On timeout the
# bot shows a graceful "all models busy" message instead of hanging.
REPLY_TIMEOUT=120

# ── Memory ───────────────────────────────────────────────────────────────────
# GETMEM_BASE_URL=                 # only for self-hosted memory
MEMORY_TOKEN_BUDGET=1500

# ── Limits & premium (Telegram Stars) ────────────────────────────────────────
FREE_DAILY_LIMIT=30
PREMIUM_DAILY_LIMIT=500
PREMIUM_PRICE_STARS=250
PREMIUM_PERIOD_DAYS=30

# ── Behaviour ────────────────────────────────────────────────────────────────
# SYSTEM_PROMPT defines WHAT your bot is — its persona/domain. Always sent first,
# ahead of recalled memory and the user's message. Set this to specialise the
# bot (finance helper, medical Q&A, study tutor, personal assistant, …).
# SYSTEM_PROMPT=You are a personal finance assistant with long-term memory...
MAX_HISTORY_TURNS=10
# Comma-separated Telegram user IDs that may use /stats and the admin dashboard.
ADMIN_IDS=

# ── Database (Postgres) ──────────────────────────────────────────────────────
POSTGRES_USER=getmem
POSTGRES_PASSWORD=getmem
POSTGRES_DB=getmem_bot
# In Docker, the host is the compose service name "db" (set per-service there).
# POSTGRES_HOST=db
# POSTGRES_PORT=5432
# Or set the full async URL directly (overrides the parts above):
# DATABASE_URL=postgresql+asyncpg://getmem:getmem@db:5432/getmem_bot

# ── API & Mini App ───────────────────────────────────────────────────────────
API_PORT=8000
# Allowed CORS origins for the API (the Mini App's origin). "*" is fine when the
# API is same-origin behind the reverse proxy.
CORS_ORIGINS=*
# Public HTTPS URL of the Mini App (used for the bot's menu button). HTTPS only.
MINIAPP_URL=
# What the Mini App calls. Same-origin behind the proxy → "/api".
NEXT_PUBLIC_API_BASE=/api
MINIAPP_PORT=3000
# For local browser testing of the Mini App outside Telegram, paste a captured
# initData string here (the frontend will use it as a dev fallback).
# NEXT_PUBLIC_DEV_INIT_DATA=

# ── Voice (optional, runs under the `voice` compose profile) ──────────────────
# First-run default only — once toggled from /admin it's stored in the DB and
# the DB value wins. Also start the service: docker compose --profile voice up
ENABLE_VOICE=false
TRANSCRIBER_URL=http://transcriber:8001
TRANSCRIBER_TIMEOUT=120
VOICE_MAX_DURATION=120
# Transcriber service tuning (see transcriber/README.md):
WHISPER_MODEL=base
WHISPER_COMPUTE_TYPE=int8
WHISPER_WARMUP=false

# ── Webhook (production only; empty = long polling) ──────────────────────────
# WEBHOOK_URL=https://bot.example.com
# WEBHOOK_PATH=/webhook
# WEBHOOK_SECRET=
# WEB_HOST=0.0.0.0
# WEB_PORT=8080
# Caddy auto-HTTPS (deploy/docker-compose.prod.yml):
# DOMAIN=bot.example.com
# ACME_EMAIL=you@example.com
