# ─────────────────────────────────────────────────────────────────────────────
#  GetMem Telegram Bot — configuration
#  Copy to `.env` and fill in. Only the first two sections are required.
# ─────────────────────────────────────────────────────────────────────────────

# ── Telegram (required) ──────────────────────────────────────────────────────
# Create a bot with @BotFather and paste the token here.
BOT_TOKEN=

# ── OpenRouter (required) ────────────────────────────────────────────────────
# Free API key: https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Optional — attribution shown on the OpenRouter dashboard / rankings.
APP_NAME=GetMem Telegram Bot
APP_URL=https://github.com/getmem-ai/getmem-telegram-bot

# ── GetMem memory (recommended — the whole point of this bot) ─────────────────
# Memory API key (gm_live_...). Get one at https://getmem.ai
# Leave empty to run the bot WITHOUT long-term memory.
GETMEM_API_KEY=
# Override only for self-hosted memory; defaults to https://memory.getmem.ai
# GETMEM_BASE_URL=
# Token budget for the recalled context injected into each prompt.
MEMORY_TOKEN_BUDGET=1500

# ── Models ───────────────────────────────────────────────────────────────────
# Comma-separated, tried in order with automatic fallback. Defaults are a solid
# set of free models; override to taste. Find more at https://openrouter.ai/models
# FREE_MODELS=deepseek/deepseek-chat-v3-0324:free,meta-llama/llama-3.3-70b-instruct:free,google/gemini-2.0-flash-exp:free
# Premium models offered after /upgrade (these cost OpenRouter credits).
# PREMIUM_MODELS=anthropic/claude-sonnet-4-6,openai/gpt-4o,google/gemini-2.5-pro

# ── Limits ───────────────────────────────────────────────────────────────────
FREE_DAILY_LIMIT=30
PREMIUM_DAILY_LIMIT=500

# ── Premium / payments (Telegram Stars) ──────────────────────────────────────
PREMIUM_PRICE_STARS=250
PREMIUM_PERIOD_DAYS=30

# ── Behaviour ────────────────────────────────────────────────────────────────
# SYSTEM_PROMPT=You are a helpful assistant with memory...
MAX_HISTORY_TURNS=10
REQUEST_TIMEOUT=60
# SQLite path (a Docker volume is mounted here in docker-compose).
DB_PATH=data/bot.db
# Comma-separated Telegram user IDs allowed to use /stats.
ADMIN_IDS=

# ── Webhook (optional) ───────────────────────────────────────────────────────
# Leave WEBHOOK_URL empty to use long polling (recommended; no domain needed).
# Set it to run in webhook mode behind the bundled Caddy proxy — see deploy/.
# WEBHOOK_URL=https://bot.example.com
# WEBHOOK_PATH=/webhook
# WEBHOOK_SECRET=
# WEB_HOST=0.0.0.0
# WEB_PORT=8080
# Used only by deploy/docker-compose.prod.yml (Caddy auto-HTTPS):
# DOMAIN=bot.example.com
# ACME_EMAIL=you@example.com
