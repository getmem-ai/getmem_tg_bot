# Caddy automatically provisions and renews a Let's Encrypt certificate for
# {$DOMAIN} and routes a single domain to all three services:
#
#   https://{$DOMAIN}/api/*    → FastAPI  (Mini App backend)
#   https://{$DOMAIN}/webhook* → bot      (Telegram webhook)
#   https://{$DOMAIN}/*        → Next.js  (Mini App frontend)
#
{
	email {$ACME_EMAIL}
}

{$DOMAIN} {
	encode zstd gzip

	handle /api/* {
		reverse_proxy api:8000
	}

	handle /webhook* {
		reverse_proxy bot:8080
	}

	handle {
		reverse_proxy miniapp:3000
	}

	header {
		Strict-Transport-Security "max-age=31536000;"
		X-Content-Type-Options "nosniff"
		-Server
	}
}
