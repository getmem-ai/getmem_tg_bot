# Base URL for the backend API. Endpoints (/me, /me/activity, ...) are relative
# to this. Defaults to "/api" when unset (useful when served behind the same
# host/proxy as the backend).
NEXT_PUBLIC_API_BASE=/api

# Local development fallback ONLY. When the app is opened in a plain browser
# (outside Telegram) there is no window.Telegram.WebApp.initData, so the app
# shows an "open in Telegram" screen. Set this to a captured raw initData
# string to develop against the API locally. NEVER set this in production.
# NEXT_PUBLIC_DEV_INIT_DATA=query_id=...&user=...&auth_date=...&hash=...
